DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
ALLOWED_HOSTS=*

DB_HOST=db
DB_PORT=5432
POSTGRES_DB=lastutis
POSTGRES_USER=lastutis
POSTGRES_PASSWORD=lastutis
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${DB_PORT}/${POSTGRES_DB}
NON_WORKING_WEEKDAYS=0,6
OWNER_EMAIL=owner@example.com
OWNER_PHONE=+54 9 11 5555-5555


# Email (dev defaults to console backend)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@lastutis.local


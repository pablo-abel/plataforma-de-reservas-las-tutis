{
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://plataforma-de-reservas-las-tutis-api.onrender.com/api/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "https://plataforma-de-reservas-las-tutis-api.onrender.com/media/:path*"
    }
  ]
}



{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://plataforma-de-reservas-las-tutis-api.onrender.com/api/$1"
    },
    {
      "source": "/media/(.*)",
      "destination": "https://plataforma-de-reservas-las-tutis-api.onrender.com/media/$1"
    }
  ]
}



